SSH_USER=root
SSH_PORT=22
REMOTE_BASE_DIR=/opt/gitlab-ha

TIMEZONE=Asia/Shanghai
SKIP_PACKAGE_INSTALL=true
SKIP_DOCKER_PULL=true

NFS_SERVER=NFS_SERVER_IP
NFS_EXPORT=/data/gitlab
NFS_MOUNT=/mnt/gitlab-nfs
# 当当前节点就是 NFS_SERVER 且 NFS_EXPORT 已是本地目录时，脚本会自动改用 bind mount。
# 跳过 NFS 挂载步骤（已手动挂载到 NFS_MOUNT 时设为 true）
SKIP_NFS_MOUNT=false
INIT_BACKUP_ENABLED=true
INIT_BACKUP_ROOT=${NFS_MOUNT}/bootstrap-backups

DB_NODE=27.204.101.29
GITLAB_NODE_1=GITLAB_NODE_IP_1
GITLAB_NODE_2=GITLAB_NODE_IP_2

POSTGRES_IMAGE=postgres:16.14
POSTGRES_PORT=5432
POSTGRES_DB=gitlabhq_production
POSTGRES_USER=gitlab
POSTGRES_PASSWORD=CHANGE_ME_DB_PASSWORD
POSTGRES_MAX_CONNECTIONS=500
POSTGRES_SHARED_BUFFERS=1GB

REDIS_IMAGE=redis:7.2
REDIS_PORT=6379
REDIS_PASSWORD=CHANGE_ME_REDIS_PASSWORD
REDIS_MASTER_NAME=gitlab-redis
SENTINEL_PORT=26379

GITLAB_IMAGE=gitlab/gitlab-ce:17.11.7-ce.0
# 统一访问入口 IP。
# 有 VIP / 负载均衡时，写 VIP / LB IP；
GITLAB_EXTERNAL_URL=http://VIP or server_name
GITLAB_BACKEND_HTTP_PORT=80
GITLAB_BACKEND_SSH_PORT=2222
GITLAB_SSH_PORT=22
GITLAB_ROOT_PASSWORD=CHANGE_ME_GITLAB_ROOT_PASSWORD
GITLAB_PUMA_WORKERS=2
GITLAB_SIDEKIQ_CONCURRENCY=10
GITLAB_LISTEN_PORT=80
GITLAB_LISTEN_HTTPS=false
GITLAB_TRUSTED_PROXIES=
# NFS 共享卷默认放宽到目录可写，避免 Gitaly 在首次创建 repositories/+gitaly 时权限被拒绝。
# 如果你已为容器运行用户做好固定 UID/GID 映射，可改为更严格的模式，例如 2775。
GITLAB_SHARED_STORAGE_MODE=2777
